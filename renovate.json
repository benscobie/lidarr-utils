{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":automergeLinters",
    ":timezone(Europe/London)",
    ":reviewer(ben)"
  ],
  "automergeType": "branch",
  "automergeStrategy": "squash",
  "branchPrefix": "renovate-",
  "digest": {
    "automerge": true
  },
  "docker-compose": {
    "enabled": false
  },
  "packageRules": [
    {
      "matchPackageNames": ["go", "golang"],
      "versioning": "go",
      "groupName": "go"
    }
  ]
}
