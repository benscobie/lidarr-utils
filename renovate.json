{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":renovatePrefix",
    ":automergeLinters",
    ":timezone(Europe/London)",
    ":reviewer(ben)"
  ],
  "automergeType": "branch",
  "automergeStrategy": "squash",
  "digest": {
    "automerge": true
  },
  "docker-compose": {
    "packageRules": [
      {
        "matchUpdateTypes": [
          "pin",
          "digest",
          "pinDigest"
        ],
        "automerge": true
      }
    ]
  },
  "packageRules": [
    {
      "matchPackageNames": ["go", "golang"],
      "versioning": "go",
      "groupName": "go"
    }
  ]
}
